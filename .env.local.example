# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ivalt_portal

# iVALT API
IVALT_API_BASE_URL=https://api.ivalt.com
IVALT_SECURITY_TOKEN=your_ivalt_security_token_here

# AWS API Gateway
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_API_GATEWAY_REST_API_ID=your_rest_api_id
AWS_API_GATEWAY_USAGE_PLAN_ID=your_usage_plan_id

# Session
SESSION_SECRET=your_super_secret_session_key_min_32_chars_here_12345678
